generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─────────────────────────────────────────────
// 認証・ユーザー
// ─────────────────────────────────────────────

enum Role {
  ADMIN
  DRIVER
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String   @map("password_hash")
  role         Role     @default(DRIVER)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  driver    Driver?
  auditLogs AuditLog[]

  @@map("users")
}

// ─────────────────────────────────────────────
// ドライバーマスタ
// ─────────────────────────────────────────────

model Driver {
  id            String   @id @default(cuid())
  userId        String?  @unique @map("user_id")
  carioDriverId String?  @unique @map("cario_driver_id")
  name          String
  phone         String?
  companyName   String?  @map("company_name")
  area          String?
  vehicleId     String?  @map("vehicle_id")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  user        User?        @relation(fields: [userId], references: [id])
  shifts      Shift[]
  assignments Assignment[]
  routeGroups RouteGroup[]
  dayReports  DriverDayReport[]
  follows     DeliveryFollow[]

  @@map("drivers")
}

// 倉庫到着時刻・終了報告（1ドライバー・1日単位）
model DriverDayReport {
  id                 String    @id @default(cuid())
  driverId           String    @map("driver_id")
  workDate           DateTime  @map("work_date") @db.Date
  warehouseArrivalAt DateTime? @map("warehouse_arrival_at")
  finishedReportedAt DateTime? @map("finished_reported_at")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  driver Driver @relation(fields: [driverId], references: [id])

  @@unique([driverId, workDate], name: "driverId_workDate")
  @@map("driver_day_reports")
}

// ─────────────────────────────────────────────
// CARIOシフト
// ─────────────────────────────────────────────

enum ShiftStatus {
  CONFIRMED
  TENTATIVE
  ABSENT
}

model Shift {
  id           String      @id @default(cuid())
  driverId     String      @map("driver_id")
  workDate     DateTime    @map("work_date") @db.Date
  startTime    DateTime?   @map("start_time") @db.Time()
  endTime      DateTime?   @map("end_time") @db.Time()
  status       ShiftStatus @default(CONFIRMED)
  source       String?
  // CARIO stale 状態管理（v4.1追加）
  isStale      Boolean     @default(false) @map("is_stale")
  sourceStatus String?     @default("OK") @map("source_status") // OK | API_FAILURE | USER_APPROVED | MOCK
  importedAt   DateTime?   @map("imported_at")
  createdAt    DateTime    @default(now()) @map("created_at")
  updatedAt    DateTime    @updatedAt @map("updated_at")

  driver Driver @relation(fields: [driverId], references: [id])

  @@unique([driverId, workDate], name: "driverId_workDate")
  @@map("shifts")
}

// ─────────────────────────────────────────────
// 配車表画像
// ─────────────────────────────────────────────

enum OcrStatus {
  PENDING
  PROCESSING
  REVIEW_REQUIRED
  CONFIRMED
  ERROR
}

model DispatchImage {
  id           String    @id @default(cuid())
  deliveryDate DateTime  @map("delivery_date") @db.Date
  area         String?
  waveNo       String?   @map("wave_no")
  imageUrl     String    @map("image_url")
  imageHash    String?   @map("image_hash")
  ocrStatus    OcrStatus @default(PENDING) @map("ocr_status")
  ocrProvider  String?   @map("ocr_provider")
  reOcrCount   Int       @default(0) @map("re_ocr_count")
  importedAt   DateTime  @default(now()) @map("imported_at")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")

  deliveryItems DeliveryItem[]
  ocrUsageLogs  OcrUsageLog[]

  @@map("dispatch_images")
}

// ─────────────────────────────────────────────
// OCR使用ログ
// ─────────────────────────────────────────────

model OcrUsageLog {
  id              String   @id @default(cuid())
  provider        String   // "ocrspace"
  dispatchImageId String?  @map("dispatch_image_id")
  imageHash       String?  @map("image_hash")
  status          String   // "success" | "error" | "skipped" | "reocr"
  confidence      String?  // "high" | "medium" | "low"
  itemCount       Int?     @map("item_count")
  errorMessage    String?  @map("error_message")
  createdAt       DateTime @default(now()) @map("created_at")

  dispatchImage DispatchImage? @relation(fields: [dispatchImageId], references: [id])

  @@map("ocr_usage_logs")
}

// ─────────────────────────────────────────────
// 配送明細（OCR読み取り結果）
// ─────────────────────────────────────────────

enum DeliveryStatus {
  PENDING_OCR
  REVIEW_REQUIRED
  ADDRESS_ERROR
  UNASSIGNED
  ASSIGNED
  IN_DELIVERY
  COMPLETED
  ABSENT
  RETURNED
  SKIPPED
}

model DeliveryItem {
  id                String         @id @default(cuid())
  dispatchImageId   String         @map("dispatch_image_id")
  dispatchKey       String?        @map("dispatch_key")
  waveNo            String?        @map("wave_no")
  vehicleNo         String?        @map("vehicle_no")
  deliverySeq       Int?           @map("delivery_seq")
  invoiceNo         String?        @map("invoice_no")
  customerName      String?        @map("customer_name")
  customerPhone     String?        @map("customer_phone")
  address           String?
  specialFlag       String?        @map("special_flag")
  normalOriconCount Int?           @default(0) @map("normal_oricon_count")
  coolerBoxCount    Int?           @default(0) @map("cooler_box_count")
  caseCount         Int?           @default(0) @map("case_count")
  totalCount        Int?           @default(0) @map("total_count")
  memo              String?
  lat               Float?
  lng               Float?
  ocrNotes          String?        @map("ocr_notes")
  ocrStatus         OcrStatus      @default(PENDING) @map("ocr_status")
  deliveryStatus    DeliveryStatus @default(PENDING_OCR) @map("delivery_status")
  // 予測値・推定値管理
  coordinateSource      String?  @map("coordinate_source")       // ValueSource
  coordinateStatus      String?  @default("ESTIMATED") @map("coordinate_status")  // ValueStatus
  coordinateConfidence  String?  @map("coordinate_confidence")   // ValueConfidence
  fieldSourceJson       String?  @map("field_source_json")       // JSON: {dispatchKey: "OCR_RAW", ...}
  fieldStatusJson       String?  @map("field_status_json")       // JSON: {dispatchKey: "CONFIRMED", ...}
  predictionWarningsJson String? @map("prediction_warnings_json") // JSON: ["OCR_COUNT_AUTO_FILLED", ...]
  // 誤配なし確認（クルーが配達時に確認）
  noMisdelivery     Boolean        @default(false) @map("no_misdelivery")
  noMisdeliveryAt   DateTime?      @map("no_misdelivery_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  dispatchImage DispatchImage @relation(fields: [dispatchImageId], references: [id])
  assignments   Assignment[]
  follows       DeliveryFollow[]

  @@map("delivery_items")
}

// フォロー（応援）：元ドライバーを残したまま別ドライバーが手伝う二重ハンドラ（1明細1ドライバー1件）
model DeliveryFollow {
  id             String   @id @default(cuid())
  deliveryItemId String   @map("delivery_item_id")
  driverId       String   @map("driver_id")
  createdAt      DateTime @default(now()) @map("created_at")

  deliveryItem DeliveryItem @relation(fields: [deliveryItemId], references: [id])
  driver       Driver       @relation(fields: [driverId], references: [id])

  @@unique([deliveryItemId, driverId], name: "deliveryItemId_driverId")
  @@map("delivery_follows")
}

// ─────────────────────────────────────────────
// ドライバー割当
// ─────────────────────────────────────────────

enum AssignmentStatus {
  ASSIGNED
  IN_DELIVERY
  COMPLETED
  ABSENT
  RETURNED
  SKIPPED
}

model Assignment {
  id             String           @id @default(cuid())
  deliveryItemId String           @unique @map("delivery_item_id")
  driverId       String           @map("driver_id")
  routeOrder     Int?             @map("route_order")
  waveNo         String?          @map("wave_no")
  loadingGroup   String?          @map("loading_group")
  isSplitLoading Boolean          @default(false) @map("is_split_loading")
  status         AssignmentStatus @default(ASSIGNED)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  deliveryItem DeliveryItem @relation(fields: [deliveryItemId], references: [id])
  driver       Driver       @relation(fields: [driverId], references: [id])

  @@map("assignments")
}

// ─────────────────────────────────────────────
// ルートグループ
// ─────────────────────────────────────────────

enum LoadingMode {
  SIMULTANEOUS
  SPLIT
}

model RouteGroup {
  id                String      @id @default(cuid())
  driverId          String      @map("driver_id")
  deliveryDate      DateTime    @map("delivery_date") @db.Date
  waveGroup         String      @map("wave_group")
  loadingMode       LoadingMode @default(SIMULTANEOUS) @map("loading_mode")
  startLocation     String?     @map("start_location")
  endLocation       String?     @map("end_location")
  returnToWarehouse Boolean     @default(true) @map("return_to_warehouse")
  createdAt         DateTime    @default(now()) @map("created_at")
  updatedAt         DateTime    @updatedAt @map("updated_at")

  driver Driver @relation(fields: [driverId], references: [id])

  @@unique([driverId, deliveryDate, waveGroup], name: "driverId_deliveryDate_waveGroup")
  @@map("route_groups")
}

// ─────────────────────────────────────────────
// 操作ログ・OCR修正履歴
// ─────────────────────────────────────────────

model AuditLog {
  id            String   @id @default(cuid())
  userId        String   @map("user_id")
  action        String
  targetType    String   @map("target_type")
  targetId      String   @map("target_id")
  beforeData    Json?    @map("before_data")
  afterData     Json?    @map("after_data")
  // 予測値・個人情報匿名化カラム（v4.1追加）
  targetIdHash  String?  @map("target_id_hash")  // SHA256 HMAC（逆検索不可）
  fieldName     String?  @map("field_name")       // 操作対象フィールド名
  source        String?                            // ValueSource
  status        String?                            // ValueStatus
  reason        String?                            // 操作理由・警告コード
  createdAt     DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@index([action])
  @@index([fieldName])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────
// OCR修正パターン学習
// ─────────────────────────────────────────────

model OcrCorrectionPattern {
  id          String   @id @default(cuid())
  fieldName   String   @map("field_name")
  beforeValue String   @map("before_value")
  afterValue  String   @map("after_value")
  patternType String   @default("exact") @map("pattern_type")
  usageCount  Int      @default(1) @map("usage_count")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@unique([fieldName, beforeValue])
  @@map("ocr_correction_patterns")
}

// ─────────────────────────────────────────────
// OCR正解セット評価
// ─────────────────────────────────────────────

model OcrGroundTruthSet {
  id              String   @id @default(cuid())
  name            String
  dispatchImageId String   @map("dispatch_image_id")
  createdAt       DateTime @default(now()) @map("created_at")

  items OcrGroundTruthItem[]

  @@map("ocr_ground_truth_sets")
}

model OcrGroundTruthItem {
  id                String  @id @default(cuid())
  setId             String  @map("set_id")
  rowNo             Int     @map("row_no")
  dispatchKey       String? @map("dispatch_key")
  invoiceNo         String? @map("invoice_no")
  customerName      String? @map("customer_name")
  customerPhone     String? @map("customer_phone")
  address           String?
  normalOriconCount Int?    @map("normal_oricon_count")
  coolerBoxCount    Int?    @map("cooler_box_count")
  caseCount         Int?    @map("case_count")
  totalCount        Int?    @map("total_count")

  set OcrGroundTruthSet @relation(fields: [setId], references: [id])

  @@map("ocr_ground_truth_items")
}

// ─────────────────────────────────────────────
// 配送表取込バッチ
// ─────────────────────────────────────────────

model DispatchImportBatch {
  id               String   @id @default(cuid())
  sourceType       String   @map("source_type")   // pdf_text|pdf_ocr|csv|excel|paste|image_ocr|camera_ocr
  originalFileUrl  String?  @map("original_file_url")
  normalizedJsonUrl  String? @map("normalized_json_url")
  l1mDebugJsonUrl    String? @map("l1m_debug_json_url")
  status             String  @default("pending")    // pending|processing|review|confirmed|error
  totalRows        Int      @default(0) @map("total_rows")
  highCount        Int      @default(0) @map("high_count")
  mediumCount      Int      @default(0) @map("medium_count")
  lowCount         Int      @default(0) @map("low_count")
  autoRescuedCount Int      @default(0) @map("auto_rescued_count")
  needsReviewCount Int      @default(0) @map("needs_review_count")
  qualityScore     Int?     @map("quality_score")
  qualityLevel     String?  @map("quality_level")
  captureMode      String?  @map("capture_mode")   // screen|paper
  layoutProfile    String?  @map("layout_profile") // l1m_cargo_list|generic
  depotName        String?  @map("depot_name")
  waveNo           String?  @map("wave_no")
  vehicleNo        String?  @map("vehicle_no")
  deliveryDate     DateTime? @map("delivery_date") @db.Date
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  rows DispatchImportRow[]

  @@map("dispatch_import_batches")
}

model DispatchImportRow {
  id             String  @id @default(cuid())
  batchId        String  @map("batch_id")
  deliveryItemId String? @map("delivery_item_id")
  rowNo          Int     @map("row_no")
  sourceType     String  @map("source_type")
  confidence     String  @default("low")  // high|medium|low
  notes          String? // JSON array of ReviewReason
  createdAt      DateTime @default(now()) @map("created_at")

  batch DispatchImportBatch @relation(fields: [batchId], references: [id])

  @@map("dispatch_import_rows")
}

// ─────────────────────────────────────────────
// 住所補正・手動ピン修正（GODOOR不使用・自社DB蓄積方式）
// ─────────────────────────────────────────────

model DeliveryLocationOverride {
  id               String   @id @default(cuid())
  normalizedAddress String  @map("normalized_address")
  postalCode       String?  @map("postal_code")
  prefecture       String?
  city             String?
  town             String?
  block            String?
  buildingName     String?  @map("building_name")
  lat              Float?
  lng              Float?
  placeId          String?  @map("place_id")
  entranceMemo     String?  @map("entrance_memo")
  buildingMemo     String?  @map("building_memo")
  nameplateMemo    String?  @map("nameplate_memo")
  accessMemo       String?  @map("access_memo")
  cautionMemo      String?  @map("caution_memo")
  parkingMemo      String?  @map("parking_memo")
  source           String   @default("manual") // manual|history|geocode
  status           String   @default("pending") // pending|approved|rejected
  usageCount       Int      @default(0) @map("usage_count")
  createdBy        String?  @map("created_by")
  approvedBy       String?  @map("approved_by")
  approvedAt       DateTime? @map("approved_at")
  // 予測値管理
  matchConfidence  String?  @map("match_confidence")  // high|medium|low（マッチ精度）
  appliedFrom      String?  @map("applied_from")       // ValueSource（どこから適用されたか）
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  @@index([normalizedAddress])
  @@map("delivery_location_overrides")
}

// ─────────────────────────────────────────────
// 増便申請（管理者・ドライバー双方が申請 / 後でCARIO連携）
// ─────────────────────────────────────────────

model ExtraVehicleRequest {
  id                 String    @id @default(cuid())
  requestDate        DateTime  @map("request_date") @db.Date   // 対象日（例: 7/3）
  depot              String                                     // 対象デポ（例: 美女木デポ）
  waveNo             String    @map("wave_no")                  // 該当便（例: 6w）
  vehicleCount       Int       @default(1) @map("vehicle_count")// 台数（例: 1台）
  assignedDriverName String?   @map("assigned_driver_name")     // 割当先（例: 石毛）
  reason             String                                     // 申請理由（自由記述・長文）
  status             String    @default("pending")              // pending|approved|rejected
  createdByUserId    String    @map("created_by_user_id")       // 申請者(User.id)
  createdByRole      String    @map("created_by_role")          // ADMIN|DRIVER
  createdByName      String?   @map("created_by_name")          // 申請者表示名
  approvedByUserId   String?   @map("approved_by_user_id")
  approvedAt         DateTime? @map("approved_at")
  rejectedReason     String?   @map("rejected_reason")
  // CARIO連携（後で実装。現状は not_sent 固定・送信ロジックは未接続）
  carioSyncStatus    String    @default("not_sent") @map("cario_sync_status") // not_sent|pending|sent|failed
  carioSentAt        DateTime? @map("cario_sent_at")
  carioRequestId     String?   @map("cario_request_id")
  createdAt          DateTime  @default(now()) @map("created_at")
  updatedAt          DateTime  @updatedAt @map("updated_at")

  @@index([status])
  @@index([requestDate])
  @@map("extra_vehicle_requests")
}
